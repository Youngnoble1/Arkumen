// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required) - Unique identifier
//   - username: string (required) - Display name
//   - points: number (required) - Total Royalty Points
//   - highestScore: number - Max score in one game
//   - favoriteCategory: string - Most played category
//   - warriorTitle: string - AI-generated title
//   - createdAt: timestamp - Creation time
//   - lastDailyChallengeDate: string - Date of last daily challenge
//   - dailyChallengeStreak: number - Current streak
//   - badges: list - List of badges
//
// Collection: games
// Document ID: {gameId}
// Fields:
//   - uid: string (required) - User ID
//   - score: number (required) - Game score
//   - streak: number - Max streak
//   - category: string (required) - Game category
//   - grade: string (required) - AI grade (S-D)
//   - message: string - AI comment
//   - mode: string (required) - Game mode
//   - createdAt: string - Game time
//
// Collection: daily_challenges
// Document ID: {date}
// Fields:
//   - date: string (required) - Date of challenge
//   - theme: string (required) - Theme
//   - questions: list (required) - List of questions
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nonsookoli757@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isValidUser(data) {
      let requiredFields = ['uid', 'username', 'points', 'highestScore', 'favoriteCategory', 'warriorTitle', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.points is number && data.points >= 0 &&
             data.highestScore is number &&
             data.favoriteCategory is string &&
             data.warriorTitle is string &&
             data.createdAt is string &&
             (!('lastDailyChallengeDate' in data) || data.lastDailyChallengeDate is string) &&
             (!('dailyChallengeStreak' in data) || data.dailyChallengeStreak is number) &&
             (!('badges' in data) || data.badges is list) &&
             (!('role' in data) || data.role is string);
    }
    
    function isValidGame(data) {
      let requiredFields = ['uid', 'score', 'category', 'grade', 'mode', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.uid == request.auth.uid &&
             data.score is number &&
             data.category is string &&
             data.mode is string &&
             data.grade is string && data.grade.size() <= 10 &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
    }
    
    match /games/{gameId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidGame(request.resource.data);
    }

    match /daily_challenges/{date} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); 
      allow update: if isAdmin();
    }
  }
}
