{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user progress, stats, and identity",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "username": { "type": "string", "description": "Display name" },
        "xp": { "type": "number", "description": "Total accumulated experience" },
        "highestScore": { "type": "number", "description": "Highest score in a single game" },
        "arkerTitle": { "type": "string", "description": "AI-generated title" },
        "rank": { "type": "string", "description": "Current rank tier" },
        "level": { "type": "number", "description": "User level" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastDailyChallengeDate": { "type": "string" },
        "dailyChallengeStreak": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isOnline": { "type": "boolean" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "xp", "highestScore", "arkerTitle", "rank", "level", "createdAt"]
    },
    "DuelInvite": {
      "title": "Duel Invite",
      "description": "An invitation for a duel between two players",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "roomId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "receiverId", "status", "createdAt"]
    },
    "GameResult": {
      "title": "Game Result",
      "description": "Records of individual quiz sessions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "score": { "type": "number" },
        "streak": { "type": "number" },
        "category": { "type": "string" },
        "grade": { "type": "string" },
        "message": { "type": "string" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "nextSteps": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "mode": { "type": "string" }
      },
      "required": ["uid", "score", "streak", "category", "grade", "message", "strengths", "weaknesses", "nextSteps", "timestamp", "mode"]
    },
    "Question": {
      "title": "Question",
      "description": "A single quiz question",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "explanation": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard"] }
      },
      "required": ["text", "options", "correctAnswer", "explanation", "difficulty"]
    },
    "BattlegroundRoom": {
      "title": "Battleground Room",
      "description": "A real-time multiplayer session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "players": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "username": { "type": "string" },
              "score": { "type": "number" },
              "currentQuestionIndex": { "type": "number" },
              "isReady": { "type": "boolean" },
              "photoURL": { "type": "string" },
              "isFinished": { "type": "boolean" }
            }
          }
        },
        "questions": { "type": "array", "items": { "$ref": "Question" } },
        "startTime": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "status", "players", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/results/{resultId}": {
      "schema": "GameResult",
      "description": "Individual game results for leaderboard and history"
    },
    "/rooms/{roomId}": {
      "schema": "BattlegroundRoom",
      "description": "Multiplayer battleground rooms"
    },
    "/invites/{inviteId}": {
      "schema": "DuelInvite",
      "description": "Duel invitations"
    }
  }
}
